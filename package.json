{
  "name": "@useinvio/nfse-sdk",
  "version": "0.3.0",
  "description": "SDK TypeScript para integração técnica com a NFS-e Nacional.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/*.d.ts",
    "dist/*.js",
    "dist/*.js.map",
    "README.md",
    "JSON_MAPPING.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js"
  },
  "keywords": [
    "nfse",
    "nfs-e",
    "nota-fiscal",
    "sefin",
    "sped"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/useinvio/nfse-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/useinvio/nfse-sdk/issues"
  },
  "homepage": "https://github.com/useinvio/nfse-sdk#readme",
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.13",
    "node-forge": "^1.3.1",
    "xml-crypto": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/node-forge": "^1.3.11",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
